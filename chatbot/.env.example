# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini

# LLM tuning
SELECT_API_LLM_TEMPERATURE=0.1
SELECT_API_LLM_MAX_TOKENS=400
CALL_API_LLM_TEMPERATURE=0.2
CALL_API_LLM_MAX_TOKENS=800
ANSWER_LLM_TEMPERATURE=0.3
ANSWER_LLM_MAX_TOKENS=1500

# CinemaStar backend
CINEMA_API_BASE_URL=https://cinema-api.duckdns.org/api
CINEMA_API_TIMEOUT=30

# Server (trong thư mục chatbot: python main.py)
CHATBOT_HOST=0.0.0.0
CHATBOT_PORT=8000
CHATBOT_RELOAD=true
CHATBOT_CORS_ORIGINS=https://cinema-star-ten.vercel.app,http://localhost:5173,http://127.0.0.1:5173

# Docker (trong thư mục chatbot)
# cp .env.example .env
# docker compose up -d --build
# Health:  GET http://localhost:8000/health
# Monitor: GET http://localhost:8000/monitor
